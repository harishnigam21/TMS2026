generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int    @id @default(autoincrement())
  name         String
  email        String @unique
  password     String
  refreshToken String @default("new") @db.VarChar(256)
  tasks        Task[]
}

model Task {
  id          Int     @id @default(autoincrement())
  title       String
  description String  @default("")
  notes       Json
  completed   Boolean @default(false)
  createdAt   String
  userId      Int
  user        User    @relation(fields: [userId], references: [id])

  @@unique([id, userId])
  @@index([userId, createdAt, id])
}
